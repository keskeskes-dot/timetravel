# Clé API Mistral (créez-en une sur https://console.mistral.ai/api-keys)
# Requise pour le chatbot Chronos et l'explication IA du quiz.
# Sans cette clé, le quiz bascule automatiquement sur une explication de repli.
MISTRAL_API_KEY=

# Modèle Mistral à utiliser (optionnel, défaut : mistral-small-latest).
MISTRAL_MODEL=mistral-small-latest
